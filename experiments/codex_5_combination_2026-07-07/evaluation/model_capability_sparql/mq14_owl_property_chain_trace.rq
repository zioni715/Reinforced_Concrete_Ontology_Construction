PREFIX ppdoc: <https://example.org/rc-progress-payment#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

ASK {
  ppdoc:hasTraceableSummary owl:propertyChainAxiom ?chain .
  ?chain rdf:rest*/rdf:first ppdoc:hasQuantityBasis .
  ?chain rdf:rest*/rdf:first ppdoc:isQuantityBasisFor .
  ?chain rdf:rest*/rdf:first ppdoc:aggregatesTo .
}
