PREFIX ppdoc: <https://example.org/rc-progress-payment#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ASK {
  ppdoc:BoQItem rdfs:subClassOf ?unitRestriction .
  ?unitRestriction owl:onProperty ppdoc:hasQuantityUnit ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onDataRange xsd:string .
  ppdoc:BoQItem rdfs:subClassOf ?quantityRestriction .
  ?quantityRestriction owl:onProperty ppdoc:hasCurrentQuantity ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onDataRange xsd:decimal .
  ppdoc:BoQItem rdfs:subClassOf ?amountRestriction .
  ?amountRestriction owl:onProperty ppdoc:hasAmount ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onDataRange xsd:decimal .
}
