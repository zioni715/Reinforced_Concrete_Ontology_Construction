PREFIX ppdoc: <https://example.org/rc-progress-payment#>
PREFIX sh: <http://www.w3.org/ns/shacl#>

ASK {
  ppdoc:BoQItemShape sh:sparql ?constraint .
  ?constraint sh:message ?message ;
      sh:select ?selectText .
  FILTER(CONTAINS(STR(?message), "금회수량"))
  FILTER(CONTAINS(?selectText, "hasCurrentQuantity"))
  FILTER(CONTAINS(?selectText, "hasUnitPrice"))
  FILTER(CONTAINS(?selectText, "hasAmount"))
}
