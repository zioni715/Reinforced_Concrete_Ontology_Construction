PREFIX ppdoc: <https://example.org/rc-progress-payment#>
PREFIX sh: <http://www.w3.org/ns/shacl#>

ASK {
  ppdoc:ProgressPaymentStatementShape a sh:NodeShape ;
      sh:targetClass ppdoc:ProgressPaymentStatement .
  FILTER EXISTS {
    ppdoc:ProgressPaymentStatementShape sh:property [
      sh:path ppdoc:hasProjectName ;
      sh:minCount 1
    ] .
  }
  FILTER EXISTS {
    ppdoc:ProgressPaymentStatementShape sh:property [
      sh:path ppdoc:hasProgressRound ;
      sh:minCount 1
    ] .
  }
  FILTER EXISTS {
    ppdoc:ProgressPaymentStatementShape sh:property [
      sh:path ppdoc:hasBaseDate ;
      sh:minCount 1
    ] .
  }
}
