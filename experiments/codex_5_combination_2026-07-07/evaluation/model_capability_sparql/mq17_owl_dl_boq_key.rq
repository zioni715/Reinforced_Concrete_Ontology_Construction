PREFIX ppdoc: <https://example.org/rc-progress-payment#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

ASK {
  ppdoc:BoQItem owl:hasKey ?keyList .
  ?keyList rdf:rest*/rdf:first ppdoc:hasSourceFileName .
  ?keyList rdf:rest*/rdf:first ppdoc:hasSourceSheetName .
  ?keyList rdf:rest*/rdf:first ppdoc:hasSourceRowNumber .
}
