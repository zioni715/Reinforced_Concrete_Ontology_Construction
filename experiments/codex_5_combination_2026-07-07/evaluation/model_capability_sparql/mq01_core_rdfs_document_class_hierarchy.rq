PREFIX ppdoc: <https://example.org/rc-progress-payment#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ASK {
  ppdoc:ProgressPaymentDocumentSet rdfs:subClassOf ppdoc:DocumentGroup .
  ppdoc:ReinforcedConcreteProgressPaymentDocuments rdfs:subClassOf ppdoc:DocumentGroup .
  ppdoc:StatementDocument rdfs:subClassOf ppdoc:DocumentGroup .
  ppdoc:ProgressPaymentStatement rdfs:subClassOf ppdoc:DocumentGroup .
  ppdoc:CostCalculationSheet rdfs:subClassOf ppdoc:Document .
  ppdoc:WorkTypeSummarySheet rdfs:subClassOf ppdoc:Document .
  ppdoc:WorkTypeDetailSheet rdfs:subClassOf ppdoc:Document .
  ppdoc:QuantityCalculationSheet rdfs:subClassOf ppdoc:Document .
}
