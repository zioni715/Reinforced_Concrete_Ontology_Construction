@prefix ppdoc: <https://example.org/rc-progress-payment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ppdoc:SKOSExtension
    a skos:ConceptScheme ;
    dcterms:title "공사기성부분 내역서 SKOS 용어 체계"@ko ;
    dcterms:description "문서유형, 공종, 세부 작업 분류, 규격 용어를 SKOS concept scheme으로 관리하기 위한 확장 모델."@ko ;
    skos:prefLabel "공사기성부분 내역서 용어 체계"@ko ;
    skos:hasTopConcept ppdoc:concept-document-type ,
        ppdoc:concept-work-type ,
        ppdoc:concept-detail-category ,
        ppdoc:concept-specification-type .

ppdoc:hasSkosConcept
    a rdf:Property ;
    rdfs:label "SKOS 개념을 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range skos:Concept ;
    rdfs:comment "RDF/RDFS 개체를 통제어휘 concept와 연결하는 매핑 관계."@ko .

ppdoc:concept-document-type
    a skos:Concept ;
    skos:prefLabel "문서 유형"@ko ;
    skos:topConceptOf ppdoc:SKOSExtension ;
    skos:narrower ppdoc:concept-progress-payment-document-set ,
        ppdoc:concept-rc-progress-payment-documents ,
        ppdoc:concept-statement-document ,
        ppdoc:concept-progress-payment-statement ,
        ppdoc:concept-cost-calculation-sheet ,
        ppdoc:concept-worktype-summary-sheet ,
        ppdoc:concept-worktype-detail-sheet ,
        ppdoc:concept-quantity-calculation-sheet .

ppdoc:concept-progress-payment-document-set
    a skos:Concept ;
    skos:prefLabel "기성서류"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:ProgressPaymentDocumentSet .

ppdoc:concept-rc-progress-payment-documents
    a skos:Concept ;
    skos:prefLabel "철근콘크리트 공종 기성서류"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:ReinforcedConcreteProgressPaymentDocuments .

ppdoc:concept-statement-document
    a skos:Concept ;
    skos:prefLabel "내역서"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:StatementDocument .

ppdoc:concept-progress-payment-statement
    a skos:Concept ;
    skos:prefLabel "공사기성부분 내역서"@ko ;
    skos:altLabel "기성 세부내역"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:ProgressPaymentStatement .

ppdoc:concept-cost-calculation-sheet
    a skos:Concept ;
    skos:prefLabel "원가계산서"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:CostCalculationSheet .

ppdoc:concept-worktype-summary-sheet
    a skos:Concept ;
    skos:prefLabel "공종별집계표"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:WorkTypeSummarySheet .

ppdoc:concept-worktype-detail-sheet
    a skos:Concept ;
    skos:prefLabel "공종별내역서"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:WorkTypeDetailSheet .

ppdoc:concept-quantity-calculation-sheet
    a skos:Concept ;
    skos:prefLabel "수량산출서"@ko ;
    skos:broader ppdoc:concept-document-type ;
    skos:exactMatch ppdoc:QuantityCalculationSheet .

ppdoc:concept-work-type
    a skos:Concept ;
    skos:prefLabel "공종"@ko ;
    skos:topConceptOf ppdoc:SKOSExtension ;
    skos:narrower ppdoc:concept-rc-work .

ppdoc:concept-rc-work
    a skos:Concept ;
    skos:prefLabel "철근콘크리트공사"@ko ;
    skos:broader ppdoc:concept-work-type ;
    skos:narrower ppdoc:concept-concrete-work ,
        ppdoc:concept-rebar-work ,
        ppdoc:concept-formwork-shoring-work ;
    skos:exactMatch ppdoc:ReinforcedConcreteWork .

ppdoc:concept-concrete-work
    a skos:Concept ;
    skos:prefLabel "콘크리트공사"@ko ;
    skos:broader ppdoc:concept-rc-work ;
    skos:exactMatch ppdoc:ConcreteWork .

ppdoc:concept-rebar-work
    a skos:Concept ;
    skos:prefLabel "철근공사"@ko ;
    skos:altLabel "철근 공사"@ko ;
    skos:broader ppdoc:concept-rc-work ;
    skos:exactMatch ppdoc:RebarWork .

ppdoc:concept-formwork-shoring-work
    a skos:Concept ;
    skos:prefLabel "거푸집 및 동바리공사"@ko ;
    skos:altLabel "거푸집공사"@ko ;
    skos:altLabel "동바리공사"@ko ;
    skos:broader ppdoc:concept-rc-work ;
    skos:exactMatch ppdoc:FormworkAndShoringWork .

ppdoc:concept-detail-category
    a skos:Concept ;
    skos:prefLabel "세부 작업 분류"@ko ;
    skos:topConceptOf ppdoc:SKOSExtension ;
    skos:narrower ppdoc:concept-ready-mixed-concrete ,
        ppdoc:concept-concrete-placement ,
        ppdoc:concept-rebar-material ,
        ppdoc:concept-rebar-assembly ,
        ppdoc:concept-formwork-installation ,
        ppdoc:concept-shoring-support-material .

ppdoc:concept-ready-mixed-concrete
    a skos:Concept ;
    skos:prefLabel "레미콘"@ko ;
    skos:altLabel "ready mixed concrete"@en ;
    skos:broader ppdoc:concept-detail-category ;
    skos:exactMatch ppdoc:ReadyMixedConcrete .

ppdoc:concept-concrete-placement
    a skos:Concept ;
    skos:prefLabel "콘크리트 타설"@ko ;
    skos:broader ppdoc:concept-detail-category ;
    skos:exactMatch ppdoc:ConcretePlacement .

ppdoc:concept-rebar-material
    a skos:Concept ;
    skos:prefLabel "철근 재료"@ko ;
    skos:broader ppdoc:concept-detail-category ;
    skos:exactMatch ppdoc:RebarMaterial .

ppdoc:concept-rebar-assembly
    a skos:Concept ;
    skos:prefLabel "철근 조립"@ko ;
    skos:altLabel "철근 가공 및 조립"@ko ;
    skos:broader ppdoc:concept-detail-category ;
    skos:exactMatch ppdoc:RebarAssembly .

ppdoc:concept-formwork-installation
    a skos:Concept ;
    skos:prefLabel "거푸집 설치"@ko ;
    skos:broader ppdoc:concept-detail-category ;
    skos:exactMatch ppdoc:FormworkInstallation .

ppdoc:concept-shoring-support-material
    a skos:Concept ;
    skos:prefLabel "동바리 지지재"@ko ;
    skos:broader ppdoc:concept-detail-category ;
    skos:exactMatch ppdoc:ShoringSupportMaterial .

ppdoc:concept-specification-type
    a skos:Concept ;
    skos:prefLabel "규격 유형"@ko ;
    skos:topConceptOf ppdoc:SKOSExtension ;
    skos:narrower ppdoc:concept-concrete-mix ,
        ppdoc:concept-rebar-spec ,
        ppdoc:concept-formwork-spec ,
        ppdoc:concept-steel-shape-spec .

ppdoc:concept-concrete-mix
    a skos:Concept ;
    skos:prefLabel "콘크리트 배합 규격"@ko ;
    skos:altLabel "강도-골재-슬럼프"@ko ;
    skos:broader ppdoc:concept-specification-type ;
    skos:exactMatch ppdoc:ConcreteMix .

ppdoc:concept-rebar-spec
    a skos:Concept ;
    skos:prefLabel "철근 규격"@ko ;
    skos:altLabel "강종-직경"@ko ;
    skos:broader ppdoc:concept-specification-type ;
    skos:exactMatch ppdoc:RebarSpec .

ppdoc:concept-formwork-spec
    a skos:Concept ;
    skos:prefLabel "거푸집 규격"@ko ;
    skos:altLabel "유로폼"@ko ;
    skos:broader ppdoc:concept-specification-type ;
    skos:exactMatch ppdoc:FormworkSpec .

ppdoc:concept-steel-shape-spec
    a skos:Concept ;
    skos:prefLabel "형강 규격"@ko ;
    skos:altLabel "H형강"@ko ;
    skos:broader ppdoc:concept-specification-type ;
    skos:exactMatch ppdoc:SteelShapeSpec .

ppdoc:worktype-rc ppdoc:hasSkosConcept ppdoc:concept-rc-work .
ppdoc:worktype-concrete ppdoc:hasSkosConcept ppdoc:concept-concrete-work .
ppdoc:worktype-rebar ppdoc:hasSkosConcept ppdoc:concept-rebar-work .
ppdoc:worktype-formwork-shoring ppdoc:hasSkosConcept ppdoc:concept-formwork-shoring-work .

ppdoc:concrete-mix-25-24-150 ppdoc:hasSkosConcept ppdoc:concept-concrete-mix .
ppdoc:rebar-spec-sd400-hd13 ppdoc:hasSkosConcept ppdoc:concept-rebar-spec .
ppdoc:formwork-spec-euroform ppdoc:hasSkosConcept ppdoc:concept-formwork-spec .
ppdoc:steel-shape-spec-h200 ppdoc:hasSkosConcept ppdoc:concept-steel-shape-spec .
