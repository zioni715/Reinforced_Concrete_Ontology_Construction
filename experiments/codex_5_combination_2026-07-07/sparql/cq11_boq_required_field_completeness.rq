PREFIX ppdoc: <https://example.org/rc-progress-payment#>

SELECT ?boqItem ?itemName ?specText ?unit ?currentQuantity ?unitPrice ?amount ?currency ?sourceRow ?sourceCell ?hierarchyPath
WHERE {
  ?boqItem a ppdoc:BoQItem ;
           ppdoc:hasItemName ?itemName ;
           ppdoc:hasSpecification ?specText ;
           ppdoc:hasQuantityUnit ?unit ;
           ppdoc:hasCurrentQuantity ?currentQuantity ;
           ppdoc:hasUnitPrice ?unitPrice ;
           ppdoc:hasAmount ?amount ;
           ppdoc:hasCurrency ?currency ;
           ppdoc:hasSourceRowNumber ?sourceRow ;
           ppdoc:hasSourceCellAddress ?sourceCell ;
           ppdoc:hasHierarchyPath ?hierarchyPath .
}
ORDER BY ?sourceRow
