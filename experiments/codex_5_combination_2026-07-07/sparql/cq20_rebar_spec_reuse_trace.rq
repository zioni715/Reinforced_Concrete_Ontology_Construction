PREFIX ppdoc: <https://example.org/rc-progress-payment#>

SELECT ?boqItem ?quantityItem ?rebarSpec ?steelGrade ?barDiameter ?yieldStrength
WHERE {
  ?boqItem a ppdoc:BoQItem ;
           ppdoc:hasRebarSpec ?rebarSpec ;
           ppdoc:hasQuantityBasis ?quantityItem .
  ?quantityItem ppdoc:hasRebarSpec ?rebarSpec .
  ?rebarSpec ppdoc:hasSteelGrade ?steelGrade ;
             ppdoc:hasBarDiameter ?barDiameter ;
             ppdoc:hasYieldStrength ?yieldStrength .
}
ORDER BY ?boqItem
