ppdoc:FormworkDetailGroup
    a rdfs:Class ;
    rdfs:label "거푸집공사 내역"@ko ;
    rdfs:subClassOf ppdoc:WorkDetailGroup .

ppdoc:WorkType
    a rdfs:Class ;
    rdfs:label "공종"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:RebarWork
    a rdfs:Class ;
    rdfs:label "철근공사"@ko ;
