ppdoc:hasInformationField
    a rdf:Property ;
    rdfs:label "정보 필드를 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:InformationField .

ppdoc:hasInspectionItem
    a rdf:Property ;
    rdfs:label "검측 항목을 가진다"@ko ;
    rdfs:domain ppdoc:InspectionDocument ;
    rdfs:range ppdoc:InspectionItem .

ppdoc:hasWorkType
    a rdf:Property ;
    rdfs:label "공종을 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:WorkType .

ppdoc:hasRelatedDocument
    a rdf:Property ;
