@prefix ppdoc: <https://example.org/rc-progress-payment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ppdoc:Ontology
    a rdfs:Resource ;
    dcterms:title "철근콘크리트 공종 기성서류 RDF/RDFS 온톨로지"@ko ;
    dcterms:description "철근콘크리트 공종 기성서류의 문서 계층, 제출 흐름, 산정 근거, 증빙, 검측 관계를 표현하기 위한 RDFS 스키마 초안."@ko ;
    dcterms:source "Ontology Development 101: A Guide to Creating Your First Ontology" ;
    rdfs:comment "본 스키마의 ppdoc: 식별자는 https://example.org/rc-progress-payment# namespace IRI와 local name을 결합한 IRI이다."@ko .

#################################################################
# Classes
#################################################################

ppdoc:ProgressPaymentEntity
    a rdfs:Class ;
    rdfs:label "기성서류 온톨로지 개체"@ko ;
    rdfs:comment "본 온톨로지에서 다루는 모든 행위자, 문서, 절차, 내역, 산출 항목의 최상위 클래스."@ko .

ppdoc:Actor
    a rdfs:Class ;
    rdfs:label "행위자"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity ;
    rdfs:comment "기성서류를 작성, 제출, 송부, 검토, 검사, 승인하는 주체."@ko .

ppdoc:Contractor
    a rdfs:Class ;
    rdfs:label "시공사"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:SiteOffice
    a rdfs:Class ;
    rdfs:label "현장"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:SupervisionHeadOffice
    a rdfs:Class ;
    rdfs:label "감리본사"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:HeadOffice
    a rdfs:Class ;
    rdfs:label "본사"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:Owner
    a rdfs:Class ;
    rdfs:label "발주처"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:Inspector
    a rdfs:Class ;
    rdfs:label "검사자"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:DocumentResource
    a rdfs:Class ;
    rdfs:label "문서 자원"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity ;
    rdfs:comment "문서군과 개별 문서를 포괄하는 상위 클래스."@ko .

ppdoc:DocumentGroup
    a rdfs:Class ;
    rdfs:label "문서군"@ko ;
    rdfs:subClassOf ppdoc:DocumentResource ;
    rdfs:comment "여러 문서 또는 하위 문서군을 묶는 단위."@ko .

ppdoc:Document
    a rdfs:Class ;
    rdfs:label "문서"@ko ;
    rdfs:subClassOf ppdoc:DocumentResource ;
    rdfs:comment "실제로 제출, 첨부, 검토되는 개별 문서."@ko .

ppdoc:Procedure
    a rdfs:Class ;
    rdfs:label "절차"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity ;
    rdfs:comment "기성서류 처리 과정의 업무 단계."@ko .

ppdoc:ContractorProgressPaymentPackage
    a rdfs:Class ;
    rdfs:label "시공사 기성서류"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:AttachmentBundle
    a rdfs:Class ;
    rdfs:label "첨부서류"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:StatementDocument
    a rdfs:Class ;
    rdfs:label "내역서"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:ProgressPaymentStatement
    a rdfs:Class ;
    rdfs:label "공사기성부분 내역서"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:MaterialReceiptAndInspectionLedger
    a rdfs:Class ;
    rdfs:label "주요자재 검수 및 수불부"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:InspectionAndPhotoDocumentGroup
    a rdfs:Class ;
    rdfs:label "검측서류 및 사진대지"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:SiteToSupervisionSubmissionPackage
    a rdfs:Class ;
    rdfs:label "현장-감리본사 공문발송 문서군"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:HeadOfficeToOwnerSubmissionPackage
    a rdfs:Class ;
    rdfs:label "본사-발주처 공문발송 문서군"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:InspectionResultReportPackage
    a rdfs:Class ;
    rdfs:label "기성검사 결과 보고"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:OfficialLetter
    a rdfs:Class ;
    rdfs:label "공문"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentInspectionRequest
    a rdfs:Class ;
    rdfs:label "기성부분 검사원"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentClaimSummary
    a rdfs:Class ;
    rdfs:label "청구기성 요약"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:AdvancePaymentDeductionStatement
    a rdfs:Class ;
    rdfs:label "선금공제 내역"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:CostCalculationSheet
    a rdfs:Class ;
    rdfs:label "원가계산서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:WorkTypeSummarySheet
    a rdfs:Class ;
    rdfs:label "공종별집계표"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:WorkTypeDetailSheet
    a rdfs:Class ;
    rdfs:label "공종별내역서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:QuantityCalculationSheet
    a rdfs:Class ;
    rdfs:label "수량산출서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:RebarQuantityCalculationSheet
    a rdfs:Class ;
    rdfs:label "철근 수량산출서"@ko ;
    rdfs:subClassOf ppdoc:QuantityCalculationSheet ;
    rdfs:comment "철근공사 내역의 수량 근거가 되는 위치, 부재명, 철근 규격, 철근 직경, 길이, 개수, 단위중량, 산출중량을 포함하는 문서."@ko .

ppdoc:ConcreteQuantityCalculationSheet
    a rdfs:Class ;
    rdfs:label "콘크리트 수량산출서"@ko ;
    rdfs:subClassOf ppdoc:QuantityCalculationSheet ;
    rdfs:comment "콘크리트공사 내역의 수량 근거가 되는 위치, 부재명, 콘크리트 강도, 길이, 폭, 높이, 산출체적을 포함하는 문서."@ko .

ppdoc:FormworkQuantityCalculationSheet
    a rdfs:Class ;
    rdfs:label "거푸집 수량산출서"@ko ;
    rdfs:subClassOf ppdoc:QuantityCalculationSheet ;
    rdfs:comment "거푸집공사 내역의 수량 근거가 되는 위치, 부재명, 거푸집 종류, 길이, 높이, 산출면적을 포함하는 문서."@ko .

ppdoc:MaterialEvidenceDocument
    a rdfs:Class ;
    rdfs:label "자재 증빙 문서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InspectionDocument
    a rdfs:Class ;
    rdfs:label "검측 문서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:PhotoSheet
    a rdfs:Class ;
    rdfs:label "사진대지"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:SupervisionProgressPaymentReport
    a rdfs:Class ;
    rdfs:label "기성부분 감리조서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InspectionExecutionPlan
    a rdfs:Class ;
    rdfs:label "공사 기성검사 수행계획서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:DetailedExecutionPlan
    a rdfs:Class ;
    rdfs:label "세부 수행계획서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:PriorReviewOpinion
    a rdfs:Class ;
    rdfs:label "사전검토 의견서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InspectorAppointmentNotice
    a rdfs:Class ;
    rdfs:label "검사자 임명 및 검사일자 통보"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentInspectionRecord
    a rdfs:Class ;
    rdfs:label "기성검사 조서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentReviewOpinion
    a rdfs:Class ;
    rdfs:label "기성검토의견서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ConstructionManagerAttendanceConfirmation
    a rdfs:Class ;
    rdfs:label "공사관리관 입회확인서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:SafetyCostEvidenceDocument
    a rdfs:Class ;
    rdfs:label "안전관리비 사용내역 및 증빙"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InsurancePaymentCertificate
    a rdfs:Class ;
    rdfs:label "보험료 납입 증명서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:OwnerRequestedDocument
    a rdfs:Class ;
    rdfs:label "기타 발주처 요청 서류"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:WorkDetailGroup
    a rdfs:Class ;
    rdfs:label "내역 그룹"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:RebarWorkDetailGroup
    a rdfs:Class ;
    rdfs:label "철근공사 내역"@ko ;
    rdfs:subClassOf ppdoc:WorkDetailGroup .

ppdoc:ConcreteWorkDetailGroup
    a rdfs:Class ;
    rdfs:label "콘크리트공사 내역"@ko ;
    rdfs:subClassOf ppdoc:WorkDetailGroup .

ppdoc:FormworkDetailGroup
    a rdfs:Class ;
    rdfs:label "거푸집공사 내역"@ko ;
    rdfs:subClassOf ppdoc:WorkDetailGroup .

ppdoc:WorkType
    a rdfs:Class ;
    rdfs:label "공종"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:RebarWork
    a rdfs:Class ;
    rdfs:label "철근공사"@ko ;
    rdfs:subClassOf ppdoc:WorkType .

ppdoc:ConcreteWork
    a rdfs:Class ;
    rdfs:label "콘크리트공사"@ko ;
    rdfs:subClassOf ppdoc:WorkType .

ppdoc:Formwork
    a rdfs:Class ;
    rdfs:label "거푸집공사"@ko ;
    rdfs:subClassOf ppdoc:WorkType .

ppdoc:SummaryAmount
    a rdfs:Class ;
    rdfs:label "집계금액"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:QuantityCalculationItem
    a rdfs:Class ;
    rdfs:label "산출 항목"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:RebarQuantityCalculationItem
    a rdfs:Class ;
    rdfs:label "철근 수량산출 항목"@ko ;
    rdfs:subClassOf ppdoc:QuantityCalculationItem .

ppdoc:ConcreteQuantityCalculationItem
    a rdfs:Class ;
    rdfs:label "콘크리트 수량산출 항목"@ko ;
    rdfs:subClassOf ppdoc:QuantityCalculationItem .

ppdoc:FormworkQuantityCalculationItem
    a rdfs:Class ;
    rdfs:label "거푸집 수량산출 항목"@ko ;
    rdfs:subClassOf ppdoc:QuantityCalculationItem .

ppdoc:InformationField
    a rdfs:Class ;
    rdfs:label "정보 필드"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:InspectionItem
    a rdfs:Class ;
    rdfs:label "검측 항목"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:ProgressPaymentInspection
    a rdfs:Class ;
    rdfs:label "기성검사"@ko ;
    rdfs:subClassOf ppdoc:Procedure .

ppdoc:DocumentInspection
    a rdfs:Class ;
    rdfs:label "서류검사"@ko ;
    rdfs:subClassOf ppdoc:Procedure .

ppdoc:SiteInspection
    a rdfs:Class ;
    rdfs:label "현장검사"@ko ;
    rdfs:subClassOf ppdoc:Procedure .

ppdoc:OwnerApproval
    a rdfs:Class ;
    rdfs:label "발주처 승인"@ko ;
    rdfs:subClassOf ppdoc:Procedure .

ppdoc:BoundStatementSubmission
    a rdfs:Class ;
    rdfs:label "제본 제출"@ko ;
    rdfs:subClassOf ppdoc:Procedure .

#################################################################
# Object properties
#################################################################

ppdoc:creates
    a rdf:Property ;
    rdfs:label "작성한다"@ko ;
    rdfs:domain ppdoc:Actor ;
    rdfs:range ppdoc:DocumentResource ;
    rdfs:comment "행위자가 기성서류 문서 또는 문서군을 작성하는 관계."@ko .

ppdoc:createdBy
    a rdf:Property ;
    rdfs:label "작성자이다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "문서 또는 문서군의 작성 주체를 나타내는 관계."@ko .

ppdoc:hasPart
    a rdf:Property ;
    rdfs:label "포함한다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "상위 문서, 문서군, 절차가 하위 문서, 하위 절차, 산출 항목을 포함하는 구성 관계."@ko .

ppdoc:isPartOf
    a rdf:Property ;
    rdfs:label "포함된다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "하위 개체가 상위 문서, 문서군, 절차에 포함됨을 나타내는 관계."@ko .

ppdoc:attaches
    a rdf:Property ;
    rdfs:label "첨부한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:DocumentResource ;
    rdfs:comment "공문 또는 문서군에 다른 문서 자원이 첨부되는 관계."@ko .

ppdoc:conditionallyIncludes
    a rdf:Property ;
    rdfs:label "조건부 포함"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:DocumentResource ;
    rdfs:comment "선금공제, 안전관리비, 보험료, 발주처 요청 서류처럼 조건에 따라 포함되는 문서 관계."@ko .

ppdoc:submittedTo
    a rdf:Property ;
    rdfs:label "제출한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "문서 또는 문서군이 제출되는 수신 주체를 나타내는 관계."@ko .

ppdoc:submittedBy
    a rdf:Property ;
    rdfs:label "제출자이다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "문서 또는 문서군을 제출한 주체를 나타내는 관계."@ko .

ppdoc:forwardedTo
    a rdf:Property ;
    rdfs:label "송부한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "검토 또는 접수 후 문서가 다음 기관이나 주체로 송부되는 관계."@ko .

ppdoc:forwardedBy
    a rdf:Property ;
    rdfs:label "송부자이다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "문서 또는 문서군을 송부한 주체를 나타내는 관계."@ko .

ppdoc:reviewedBy
    a rdf:Property ;
    rdfs:label "검토한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "문서가 특정 주체에 의해 검토됨을 나타내는 관계."@ko .

ppdoc:inspectedBy
    a rdf:Property ;
    rdfs:label "검사한다"@ko ;
    rdfs:domain ppdoc:Procedure ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "검사 절차가 특정 검사자 또는 검사 주체에 의해 수행됨을 나타내는 관계."@ko .

ppdoc:approvedBy
    a rdf:Property ;
    rdfs:label "승인한다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:Actor ;
    rdfs:comment "문서, 결과, 절차가 특정 행위자에게 승인됨을 나타내는 관계."@ko .

ppdoc:precedes
    a rdf:Property ;
    rdfs:label "후속 단계로 이어진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "문서 흐름 또는 절차 흐름에서 현재 개체가 다음 개체보다 선행함을 나타내는 관계."@ko .

ppdoc:follows
    a rdf:Property ;
    rdfs:label "이전 단계이다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "문서 흐름 또는 절차 흐름에서 현재 개체가 이전 개체를 따름을 나타내는 관계."@ko .

ppdoc:aggregatesTo
    a rdf:Property ;
    rdfs:label "집계된다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "하위 공종 내역, 수량, 금액이 상위 집계 항목으로 합산되는 관계."@ko .

ppdoc:aggregates
    a rdf:Property ;
    rdfs:label "집계한다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "상위 집계 개체가 하위 내역 또는 금액을 집계함을 나타내는 관계."@ko .

ppdoc:isQuantityBasisFor
    a rdf:Property ;
    rdfs:label "산출 근거가 된다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:WorkDetailGroup ;
    rdfs:comment "수량산출서 또는 산출 항목이 공종별 내역의 수량 산정 근거가 됨을 나타내는 관계."@ko .

ppdoc:hasQuantityBasis
    a rdf:Property ;
    rdfs:label "산출 근거를 가진다"@ko ;
    rdfs:domain ppdoc:WorkDetailGroup ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "공종별 내역이 수량산출서 또는 산출 항목을 산정 근거로 가짐을 나타내는 관계."@ko .

ppdoc:evidences
    a rdf:Property ;
    rdfs:label "증빙한다"@ko ;
    rdfs:domain ppdoc:MaterialEvidenceDocument ;
    rdfs:range ppdoc:WorkDetailGroup ;
    rdfs:comment "자재 증빙 문서가 특정 공종별 내역을 증빙함을 나타내는 관계."@ko .

ppdoc:hasEvidence
    a rdf:Property ;
    rdfs:label "증빙자료를 가진다"@ko ;
    rdfs:domain ppdoc:WorkDetailGroup ;
    rdfs:range ppdoc:MaterialEvidenceDocument ;
    rdfs:comment "공종별 내역이 관련 자재 증빙 문서를 가짐을 나타내는 관계."@ko .

ppdoc:isInspectionBasisFor
    a rdf:Property ;
    rdfs:label "검측 근거가 된다"@ko ;
    rdfs:domain ppdoc:InspectionDocument ;
    rdfs:range ppdoc:WorkDetailGroup ;
    rdfs:comment "검측 문서가 특정 공종별 내역의 시공 확인 근거가 됨을 나타내는 관계."@ko .

ppdoc:hasInspectionBasis
    a rdf:Property ;
    rdfs:label "검측 근거를 가진다"@ko ;
    rdfs:domain ppdoc:WorkDetailGroup ;
    rdfs:range ppdoc:InspectionDocument ;
    rdfs:comment "공종별 내역이 관련 검측 문서를 근거로 가짐을 나타내는 관계."@ko .

ppdoc:isPhotoEvidenceFor
    a rdf:Property ;
    rdfs:label "사진 근거가 된다"@ko ;
    rdfs:domain ppdoc:PhotoSheet ;
    rdfs:range ppdoc:ProgressPaymentEntity ;
    rdfs:comment "사진대지가 문서, 검측 문서, 검사 절차의 사진 증빙이 됨을 나타내는 관계."@ko .

ppdoc:hasPhotoEvidence
    a rdf:Property ;
    rdfs:label "사진 근거를 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:PhotoSheet ;
    rdfs:comment "문서, 검측 문서, 검사 절차가 사진대지를 증빙 자료로 가짐을 나타내는 관계."@ko .

ppdoc:hasInformationField
    a rdf:Property ;
    rdfs:label "정보 필드를 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:InformationField ;
    rdfs:comment "문서, 내역, 산출서가 포함해야 하는 정보 필드 정의를 연결하는 관계."@ko .

ppdoc:hasInspectionItem
    a rdf:Property ;
    rdfs:label "검측 항목을 가진다"@ko ;
    rdfs:domain ppdoc:InspectionDocument ;
    rdfs:range ppdoc:InspectionItem ;
    rdfs:comment "검측 문서가 확인해야 하는 세부 검측 항목을 연결하는 관계."@ko .

ppdoc:hasWorkType
    a rdf:Property ;
    rdfs:label "공종을 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:WorkType ;
    rdfs:comment "내역, 산출 항목, 문서가 철근, 콘크리트, 거푸집 등 공종과 연결됨을 나타내는 관계."@ko .

ppdoc:hasRelatedDocument
    a rdf:Property ;
    rdfs:label "관련 문서를 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:DocumentResource ;
    rdfs:comment "개체와 의미적으로 관련된 문서 자원을 연결하는 보조 관계."@ko .

ppdoc:hasSourceDocument
    a rdf:Property ;
    rdfs:label "출처 문서를 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:DocumentResource ;
    rdfs:comment "추출값 또는 인스턴스의 원천 문서 자원을 연결하는 관계."@ko .

