@prefix ppdoc: <https://example.org/rc-progress-payment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ppdoc:Ontology
    a rdfs:Resource ;
    dcterms:title "철근콘크리트 공종 기성서류 RDF/RDFS 온톨로지"@ko ;
    dcterms:description "철근콘크리트 공종 기성서류의 문서 계층, 제출 흐름, 산정 근거, 증빙, 검측 관계를 표현하기 위한 RDFS 스키마 초안."@ko .

#################################################################
# Classes
#################################################################

ppdoc:ProgressPaymentEntity
    a rdfs:Class ;
    rdfs:label "기성서류 온톨로지 개체"@ko ;
    rdfs:comment "본 온톨로지에서 다루는 모든 행위자, 문서, 절차, 내역, 산출 항목의 최상위 클래스."@ko .

ppdoc:Actor
    a rdfs:Class ;
    rdfs:label "행위자"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity ;
    rdfs:comment "기성서류를 작성, 제출, 송부, 검토, 검사, 승인하는 주체."@ko .

ppdoc:Contractor
    a rdfs:Class ;
    rdfs:label "시공사"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:SiteOffice
    a rdfs:Class ;
    rdfs:label "현장"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:SupervisionHeadOffice
    a rdfs:Class ;
    rdfs:label "감리본사"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:HeadOffice
    a rdfs:Class ;
    rdfs:label "본사"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:Owner
    a rdfs:Class ;
    rdfs:label "발주처"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:Inspector
    a rdfs:Class ;
    rdfs:label "검사자"@ko ;
    rdfs:subClassOf ppdoc:Actor .

ppdoc:DocumentResource
    a rdfs:Class ;
    rdfs:label "문서 자원"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity ;
    rdfs:comment "문서군과 개별 문서를 포괄하는 상위 클래스."@ko .

ppdoc:DocumentGroup
    a rdfs:Class ;
    rdfs:label "문서군"@ko ;
    rdfs:subClassOf ppdoc:DocumentResource ;
    rdfs:comment "여러 문서 또는 하위 문서군을 묶는 단위."@ko .

ppdoc:Document
    a rdfs:Class ;
    rdfs:label "문서"@ko ;
    rdfs:subClassOf ppdoc:DocumentResource ;
    rdfs:comment "실제로 제출, 첨부, 검토되는 개별 문서."@ko .

ppdoc:Procedure
    a rdfs:Class ;
    rdfs:label "절차"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity ;
    rdfs:comment "기성서류 처리 과정의 업무 단계."@ko .

ppdoc:ContractorProgressPaymentPackage
    a rdfs:Class ;
    rdfs:label "시공사 기성서류"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:AttachmentBundle
    a rdfs:Class ;
    rdfs:label "첨부서류"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:StatementDocument
    a rdfs:Class ;
    rdfs:label "내역서"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:ProgressPaymentStatement
    a rdfs:Class ;
    rdfs:label "공사기성부분 내역서"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:MaterialReceiptAndInspectionLedger
    a rdfs:Class ;
    rdfs:label "주요자재 검수 및 수불부"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:InspectionAndPhotoDocumentGroup
    a rdfs:Class ;
    rdfs:label "검측서류 및 사진대지"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:SiteToSupervisionSubmissionPackage
    a rdfs:Class ;
    rdfs:label "현장-감리본사 공문발송 문서군"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:HeadOfficeToOwnerSubmissionPackage
    a rdfs:Class ;
    rdfs:label "본사-발주처 공문발송 문서군"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:InspectionResultReportPackage
    a rdfs:Class ;
    rdfs:label "기성검사 결과 보고"@ko ;
    rdfs:subClassOf ppdoc:DocumentGroup .

ppdoc:OfficialLetter
    a rdfs:Class ;
    rdfs:label "공문"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentInspectionRequest
    a rdfs:Class ;
    rdfs:label "기성부분 검사원"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentClaimSummary
    a rdfs:Class ;
    rdfs:label "청구기성 요약"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:AdvancePaymentDeductionStatement
    a rdfs:Class ;
    rdfs:label "선금공제 내역"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:CostCalculationSheet
    a rdfs:Class ;
    rdfs:label "원가계산서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:WorkTypeSummarySheet
    a rdfs:Class ;
    rdfs:label "공종별집계표"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:WorkTypeDetailSheet
    a rdfs:Class ;
    rdfs:label "공종별내역서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:QuantityCalculationSheet
    a rdfs:Class ;
    rdfs:label "수량산출서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:MaterialEvidenceDocument
    a rdfs:Class ;
    rdfs:label "자재 증빙 문서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InspectionDocument
    a rdfs:Class ;
    rdfs:label "검측 문서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:PhotoSheet
    a rdfs:Class ;
    rdfs:label "사진대지"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:SupervisionProgressPaymentReport
    a rdfs:Class ;
    rdfs:label "기성부분 감리조서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InspectionExecutionPlan
    a rdfs:Class ;
    rdfs:label "공사 기성검사 수행계획서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:DetailedExecutionPlan
    a rdfs:Class ;
    rdfs:label "세부 수행계획서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:PriorReviewOpinion
    a rdfs:Class ;
    rdfs:label "사전검토 의견서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InspectorAppointmentNotice
    a rdfs:Class ;
