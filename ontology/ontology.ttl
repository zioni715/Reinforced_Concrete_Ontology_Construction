ppdoc:ProgressPaymentInspectionRecord
    a rdfs:Class ;
    rdfs:label "기성검사 조서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ProgressPaymentReviewOpinion
    a rdfs:Class ;
    rdfs:label "기성검토의견서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:ConstructionManagerAttendanceConfirmation
    a rdfs:Class ;
    rdfs:label "공사관리관 입회확인서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:SafetyCostEvidenceDocument
    a rdfs:Class ;
    rdfs:label "안전관리비 사용내역 및 증빙"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:InsurancePaymentCertificate
    a rdfs:Class ;
    rdfs:label "보험료 납입 증명서"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:OwnerRequestedDocument
    a rdfs:Class ;
    rdfs:label "기타 발주처 요청 서류"@ko ;
    rdfs:subClassOf ppdoc:Document .

ppdoc:WorkDetailGroup
    a rdfs:Class ;
    rdfs:label "내역 그룹"@ko ;
    rdfs:subClassOf ppdoc:ProgressPaymentEntity .

ppdoc:RebarWorkDetailGroup
    a rdfs:Class ;
