    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:DocumentResource .

ppdoc:hasSourceDocument
    a rdf:Property ;
    rdfs:label "출처 문서를 가진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:DocumentResource .

