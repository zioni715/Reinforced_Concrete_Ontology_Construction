ppdoc:BoundStatementSubmission
    a rdfs:Class ;
    rdfs:label "제본 제출"@ko ;
    rdfs:subClassOf ppdoc:Procedure .

#################################################################
# Object properties
#################################################################

ppdoc:creates
    a rdf:Property ;
    rdfs:label "작성한다"@ko ;
    rdfs:domain ppdoc:Actor ;
    rdfs:range ppdoc:DocumentResource .

ppdoc:createdBy
    a rdf:Property ;
    rdfs:label "작성자이다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor .

ppdoc:hasPart
    a rdf:Property ;
    rdfs:label "포함한다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:isPartOf
    a rdf:Property ;
    rdfs:label "포함된다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:attaches
    a rdf:Property ;
    rdfs:label "첨부한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:DocumentResource .

ppdoc:conditionallyIncludes
    a rdf:Property ;
    rdfs:label "조건부 포함"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:DocumentResource .

ppdoc:submittedTo
    a rdf:Property ;
    rdfs:label "제출한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor .

ppdoc:submittedBy
    a rdf:Property ;
    rdfs:label "제출자이다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor .

ppdoc:forwardedTo
    a rdf:Property ;
    rdfs:label "송부한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor .

ppdoc:forwardedBy
    a rdf:Property ;
    rdfs:label "송부자이다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor .

ppdoc:reviewedBy
    a rdf:Property ;
    rdfs:label "검토한다"@ko ;
    rdfs:domain ppdoc:DocumentResource ;
    rdfs:range ppdoc:Actor .

ppdoc:inspectedBy
    a rdf:Property ;
    rdfs:label "검사한다"@ko ;
    rdfs:domain ppdoc:Procedure ;
    rdfs:range ppdoc:Actor .

ppdoc:approvedBy
    a rdf:Property ;
    rdfs:label "승인한다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:Actor .

ppdoc:precedes
    a rdf:Property ;
    rdfs:label "후속 단계로 이어진다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:follows
    a rdf:Property ;
    rdfs:label "이전 단계이다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:aggregatesTo
    a rdf:Property ;
    rdfs:label "집계된다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:aggregates
    a rdf:Property ;
    rdfs:label "집계한다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:isQuantityBasisFor
    a rdf:Property ;
    rdfs:label "산출 근거가 된다"@ko ;
    rdfs:domain ppdoc:ProgressPaymentEntity ;
    rdfs:range ppdoc:WorkDetailGroup .

ppdoc:hasQuantityBasis
    a rdf:Property ;
    rdfs:label "산출 근거를 가진다"@ko ;
    rdfs:domain ppdoc:WorkDetailGroup ;
    rdfs:range ppdoc:ProgressPaymentEntity .

ppdoc:evidences
    a rdf:Property ;
    rdfs:label "증빙한다"@ko ;
    rdfs:domain ppdoc:MaterialEvidenceDocument ;
    rdfs:range ppdoc:WorkDetailGroup .

ppdoc:hasEvidence
    a rdf:Property ;
    rdfs:label "증빙자료를 가진다"@ko ;
    rdfs:domain ppdoc:WorkDetailGroup ;
    rdfs:range ppdoc:MaterialEvidenceDocument .

ppdoc:isInspectionBasisFor
    a rdf:Property ;
    rdfs:label "검측 근거가 된다"@ko ;
    rdfs:domain ppdoc:InspectionDocument ;
    rdfs:range ppdoc:WorkDetailGroup .

ppdoc:hasInspectionBasis
    a rdf:Property ;
    rdfs:label "검측 근거를 가진다"@ko ;
    rdfs:domain ppdoc:WorkDetailGroup ;
    rdfs:range ppdoc:InspectionDocument .

ppdoc:isPhotoEvidenceFor
    a rdf:Property ;
