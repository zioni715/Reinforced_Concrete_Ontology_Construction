@prefix ppdoc: <https://example.org/rc-progress-payment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Progress payment statement document structure
#################################################################

ppdoc:progress-payment-documents-sample
    a ppdoc:ProgressPaymentDocumentSet ;
    rdfs:label "기성서류"@ko ;
    ppdoc:hasPart ppdoc:rc-progress-payment-documents-sample .

ppdoc:rc-progress-payment-documents-sample
    a ppdoc:ReinforcedConcreteProgressPaymentDocuments ;
    rdfs:label "철근콘크리트 공종 기성서류"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-documents-sample ;
    ppdoc:hasPart ppdoc:statement-document-sample .

ppdoc:statement-document-sample
    a ppdoc:StatementDocument ;
    rdfs:label "내역서"@ko ;
    ppdoc:isPartOf ppdoc:rc-progress-payment-documents-sample ;
    ppdoc:hasPart ppdoc:progress-payment-statement-sample .

ppdoc:progress-payment-statement-sample
    a ppdoc:ProgressPaymentStatement ;
    rdfs:label "공사기성부분 내역서"@ko ;
    ppdoc:isPartOf ppdoc:statement-document-sample ;
    ppdoc:hasDocumentIdentifier "sample-progress-payment-statement" ;
    ppdoc:hasDocumentTitle "철근콘크리트 공종 공사기성부분 내역서" ;
    ppdoc:hasProjectName "화성동탄(2)A4-1BL아파트신축공사" ;
    ppdoc:hasProgressRound "예시 기성회차" ;
    ppdoc:hasBaseDate "2026-06-30"^^xsd:date ;
    ppdoc:hasSourceFileName "Documents/화성동탄(2)A4-1BL아파트신축공사/3. 기성 세부내역.xlsx" ;
    ppdoc:hasPart ppdoc:cost-calculation-sheet-sample ,
        ppdoc:work-type-summary-sheet-sample ,
        ppdoc:work-type-detail-sheet-sample ,
        ppdoc:quantity-calculation-sheet-sample .

ppdoc:cost-calculation-sheet-sample
    a ppdoc:CostCalculationSheet ;
    rdfs:label "원가계산서"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-statement-sample ;
    ppdoc:hasSourceSheetName "1.총괄원가계산서" ;
    ppdoc:hasWorkTypeSection ppdoc:cost-section-rc-work .

ppdoc:work-type-summary-sheet-sample
    a ppdoc:WorkTypeSummarySheet ;
    rdfs:label "공종별집계표"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-statement-sample ;
    ppdoc:hasWorkTypeSection ppdoc:summary-section-concrete-work ,
        ppdoc:summary-section-rebar-work ,
        ppdoc:summary-section-formwork-shoring-work ;
    ppdoc:hasPart ppdoc:summary-rc-work-sample ,
        ppdoc:summary-concrete-work-sample ,
        ppdoc:summary-rebar-work-sample ,
        ppdoc:summary-formwork-shoring-work-sample .

ppdoc:work-type-detail-sheet-sample
    a ppdoc:WorkTypeDetailSheet ;
    rdfs:label "공종별내역서"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-statement-sample ;
    ppdoc:hasSourceSheetName "기성 세부내역" ;
    ppdoc:hasWorkType ppdoc:worktype-rc ;
    ppdoc:hasDataFormat ppdoc:boq-item-table-format-sample ;
    ppdoc:hasWorkTypeSection ppdoc:detail-section-concrete-work ,
        ppdoc:detail-section-rebar-work ,
        ppdoc:detail-section-formwork-shoring-work ;
    ppdoc:hasBoQItem ppdoc:boq-concrete-ready-mix-001 ,
        ppdoc:boq-concrete-placement-001 ,
        ppdoc:boq-rebar-material-001 ,
        ppdoc:boq-rebar-assembly-001 ,
        ppdoc:boq-formwork-installation-001 ,
        ppdoc:boq-shoring-support-001 ;
    ppdoc:hasInformationField ppdoc:field-item-name ,
        ppdoc:field-specification ,
        ppdoc:field-quantity-unit ,
        ppdoc:field-source-row-number ,
        ppdoc:field-hierarchy-path ,
        ppdoc:field-contract-quantity ,
        ppdoc:field-previous-quantity ,
        ppdoc:field-current-quantity ,
        ppdoc:field-cumulative-quantity ,
        ppdoc:field-unit-price ,
        ppdoc:field-amount ,
        ppdoc:field-currency .

ppdoc:quantity-calculation-sheet-sample
    a ppdoc:QuantityCalculationSheet ;
    rdfs:label "수량산출서"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-statement-sample ;
    ppdoc:hasWorkTypeSection ppdoc:quantity-section-concrete-work ,
        ppdoc:quantity-section-rebar-work ,
        ppdoc:quantity-section-formwork-shoring-work ;
    ppdoc:hasPart ppdoc:quantity-concrete-slab-001 ,
        ppdoc:quantity-rebar-beam-001 ,
        ppdoc:quantity-formwork-wall-001 ,
        ppdoc:quantity-shoring-support-001 .

#################################################################
# Second-level work type sections
#################################################################

ppdoc:cost-section-rc-work
    a ppdoc:CostWorkTypeSection ;
    rdfs:label "철근콘크리트공사 원가계산 구간"@ko ;
    ppdoc:isPartOf ppdoc:cost-calculation-sheet-sample ;
    ppdoc:hasWorkType ppdoc:worktype-rc ;
    ppdoc:hasCostItem ppdoc:cost-rc-direct-cost ,
        ppdoc:cost-rc-indirect-cost ,
        ppdoc:cost-rc-markup-cost ,
        ppdoc:cost-rc-tax-total-cost .

ppdoc:cost-rc-direct-cost
    a ppdoc:DirectCostItem ;
    rdfs:label "철근콘크리트공사 직접공사비"@ko ;
    ppdoc:isPartOf ppdoc:cost-section-rc-work ;
    ppdoc:hasWorkType ppdoc:worktype-rc ;
    ppdoc:hasCostCategory "직접공사비" ;
    ppdoc:hasCostItemName "재료비, 직접노무비, 직접경비" ;
    ppdoc:hasAmount "235670000"^^xsd:decimal ;
    ppdoc:hasCurrency "KRW" ;
    ppdoc:hasCalculationFormula "공종별집계표의 철근콘크리트공사 재료비, 노무비, 경비 비목 합계" ;
    ppdoc:hasCostBasis ppdoc:summary-rc-work-sample .

ppdoc:cost-rc-indirect-cost
    a ppdoc:IndirectCostItem ;
    rdfs:label "철근콘크리트공사 간접비 및 법정경비"@ko ;
    ppdoc:isPartOf ppdoc:cost-section-rc-work ;
    ppdoc:hasWorkType ppdoc:worktype-rc ;
    ppdoc:hasCostCategory "간접비 및 법정경비" ;
    ppdoc:hasCostItemName "간접노무비, 기타경비, 산재보험료, 고용보험료, 퇴직공제부금비, 산업안전보건관리비, 보험료, 보증수수료" ;
    ppdoc:hasRate "0.120"^^xsd:decimal ;
    ppdoc:hasAmount "28280400"^^xsd:decimal ;
    ppdoc:hasCurrency "KRW" ;
    ppdoc:hasCalculationFormula "철근콘크리트공사 직접비 또는 노무비 기준 요율 적용" ;
    ppdoc:hasCostBasis ppdoc:cost-rc-direct-cost .

ppdoc:cost-rc-markup-cost
    a ppdoc:MarkupCostItem ;
    rdfs:label "철근콘크리트공사 일반관리비 및 이윤"@ko ;
    ppdoc:isPartOf ppdoc:cost-section-rc-work ;
    ppdoc:hasWorkType ppdoc:worktype-rc ;
    ppdoc:hasCostCategory "일반관리비 및 이윤" ;
    ppdoc:hasCostItemName "일반관리비, 이윤" ;
    ppdoc:hasRate "0.090"^^xsd:decimal ;
    ppdoc:hasAmount "23755536"^^xsd:decimal ;
    ppdoc:hasCurrency "KRW" ;
    ppdoc:hasCalculationFormula "철근콘크리트공사 재료비, 노무비, 경비 및 일반관리비 기준 요율 적용" ;
    ppdoc:hasCostBasis ppdoc:cost-rc-direct-cost ,
        ppdoc:cost-rc-indirect-cost .

ppdoc:cost-rc-tax-total-cost
    a ppdoc:TaxAndTotalCostItem ;
    rdfs:label "철근콘크리트공사 세금 및 총액"@ko ;
    ppdoc:isPartOf ppdoc:cost-section-rc-work ;
    ppdoc:hasWorkType ppdoc:worktype-rc ;
    ppdoc:hasCostCategory "세금 및 총액" ;
    ppdoc:hasCostItemName "부가가치세, 총도급액, 총공사비" ;
    ppdoc:hasRate "0.100"^^xsd:decimal ;
    ppdoc:hasAmount "28770594"^^xsd:decimal ;
    ppdoc:hasCurrency "KRW" ;
    ppdoc:hasCalculationFormula "철근콘크리트공사 원가 항목 합계에 세금 및 총액 산정 규칙 적용" ;
    ppdoc:hasCostBasis ppdoc:cost-rc-direct-cost ,
        ppdoc:cost-rc-indirect-cost ,
        ppdoc:cost-rc-markup-cost .

ppdoc:summary-section-concrete-work
    a ppdoc:SummaryWorkTypeSection ;
    rdfs:label "콘크리트공사 집계 구간"@ko ;
