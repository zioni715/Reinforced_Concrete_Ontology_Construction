    rdfs:label "거푸집 치수 확인"@ko .

ppdoc:support-installation-check-sample
    a ppdoc:InspectionItem ;
    rdfs:label "동바리 설치 확인"@ko .

ppdoc:vertical-horizontal-check-sample
    a ppdoc:InspectionItem ;
    rdfs:label "수직도 및 수평도 확인"@ko .

ppdoc:rebar-photo-sheet-sample
    a ppdoc:PhotoSheet ;
    rdfs:label "철근 배근 사진대지"@ko ;
    ppdoc:isPhotoEvidenceFor ppdoc:rebar-inspection-checklist-sample .

ppdoc:concrete-photo-sheet-sample
    a ppdoc:PhotoSheet ;
    rdfs:label "콘크리트 타설 사진대지"@ko ;
    ppdoc:isPhotoEvidenceFor ppdoc:concrete-pouring-daily-report-sample .

ppdoc:formwork-photo-sheet-sample
    a ppdoc:PhotoSheet ;
    rdfs:label "거푸집 설치 사진대지"@ko ;
    ppdoc:isPhotoEvidenceFor ppdoc:formwork-installation-checklist-sample .

#################################################################
# Review, inspection, approval flow
#################################################################

ppdoc:site-to-supervision-package-sample
    a ppdoc:SiteToSupervisionSubmissionPackage ;
    rdfs:label "현장-감리본사 공문발송 문서군"@ko ;
    ppdoc:forwardedBy ppdoc:site-office-sample ;
    ppdoc:forwardedTo ppdoc:supervision-head-office-sample ;
    ppdoc:hasPart ppdoc:supervision-report-sample ,
        ppdoc:inspection-plan-sample ,
        ppdoc:inspection-request-sample .

ppdoc:supervision-report-sample
    a ppdoc:SupervisionProgressPaymentReport ;
    rdfs:label "기성부분 감리조서"@ko ;
    ppdoc:reviewedBy ppdoc:supervision-head-office-sample .

ppdoc:inspection-plan-sample
    a ppdoc:InspectionExecutionPlan ;
    rdfs:label "공사 기성검사 수행계획서"@ko ;
    ppdoc:hasPart ppdoc:detailed-execution-plan-sample ,
        ppdoc:prior-review-opinion-sample .

ppdoc:detailed-execution-plan-sample
    a ppdoc:DetailedExecutionPlan ;
    rdfs:label "세부 수행계획서"@ko .

ppdoc:prior-review-opinion-sample
    a ppdoc:PriorReviewOpinion ;
    rdfs:label "기성검사원에 대한 사전검토 의견서"@ko .

ppdoc:head-office-to-owner-package-sample
    a ppdoc:HeadOfficeToOwnerSubmissionPackage ;
    rdfs:label "본사-발주처 공문발송 문서군"@ko ;
    ppdoc:forwardedBy ppdoc:head-office-sample ;
    ppdoc:submittedTo ppdoc:owner-sample ;
    ppdoc:hasPart ppdoc:inspector-appointment-notice-sample ;
    ppdoc:attaches ppdoc:site-to-supervision-package-sample .

ppdoc:inspector-appointment-notice-sample
    a ppdoc:InspectorAppointmentNotice ;
    rdfs:label "검사자 임명 및 검사일자 통보"@ko .

ppdoc:progress-payment-inspection-sample
    a ppdoc:ProgressPaymentInspection ;
    rdfs:label "기성검사"@ko ;
    ppdoc:inspectedBy ppdoc:inspector-sample ;
    ppdoc:hasPart ppdoc:document-inspection-sample ,
        ppdoc:site-inspection-sample ,
        ppdoc:inspection-photo-sheet-sample ;
    ppdoc:precedes ppdoc:inspection-result-report-sample .

ppdoc:document-inspection-sample
    a ppdoc:DocumentInspection ;
    rdfs:label "서류검사"@ko .

ppdoc:site-inspection-sample
    a ppdoc:SiteInspection ;
    rdfs:label "현장검사"@ko .

ppdoc:inspection-photo-sheet-sample
    a ppdoc:PhotoSheet ;
    rdfs:label "검사사진 대지"@ko ;
    ppdoc:isPhotoEvidenceFor ppdoc:progress-payment-inspection-sample .

ppdoc:inspection-result-report-sample
    a ppdoc:InspectionResultReportPackage ;
    rdfs:label "기성검사 결과 보고"@ko ;
    ppdoc:submittedTo ppdoc:owner-sample ;
    ppdoc:hasPart ppdoc:inspection-record-sample ,
        ppdoc:review-opinion-sample ,
        ppdoc:attendance-confirmation-sample ,
        ppdoc:result-photo-attachment-sample ;
    ppdoc:precedes ppdoc:owner-approval-sample .

ppdoc:inspection-record-sample
    a ppdoc:ProgressPaymentInspectionRecord ;
    rdfs:label "기성검사 조서"@ko ;
    ppdoc:hasSourceFileName "검증용 실제 사례 문서: 기성검사조서 PDF" .

ppdoc:review-opinion-sample
    a ppdoc:ProgressPaymentReviewOpinion ;
    rdfs:label "기성검토의견서"@ko .

ppdoc:attendance-confirmation-sample
    a ppdoc:ConstructionManagerAttendanceConfirmation ;
    rdfs:label "공사관리관 입회확인서"@ko .

ppdoc:result-photo-attachment-sample
    a ppdoc:PhotoSheet ;
    rdfs:label "사진첨부"@ko .

ppdoc:owner-approval-sample
    a ppdoc:OwnerApproval ;
    rdfs:label "발주처 승인"@ko ;
    ppdoc:approvedBy ppdoc:owner-sample ;
    ppdoc:precedes ppdoc:bound-statement-submission-sample .

ppdoc:bound-statement-submission-sample
    a ppdoc:BoundStatementSubmission ;
    rdfs:label "기성서류 내역서 제본 제출"@ko .
