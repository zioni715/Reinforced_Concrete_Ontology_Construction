#################################################################
# Quantity calculation basis
#################################################################

ppdoc:quantity-calculation-sheet-sample
    a ppdoc:QuantityCalculationSheet ;
    rdfs:label "수량산출서"@ko ;
    ppdoc:hasPart ppdoc:rebar-quantity-sheet-sample ,
        ppdoc:concrete-quantity-sheet-sample ,
        ppdoc:formwork-quantity-sheet-sample .

ppdoc:rebar-quantity-sheet-sample
    a ppdoc:RebarQuantityCalculationSheet ;
    rdfs:label "철근 수량산출서"@ko ;
    ppdoc:isPartOf ppdoc:quantity-calculation-sheet-sample ;
    ppdoc:hasInformationField ppdoc:field-location ,
        ppdoc:field-member-name ,
        ppdoc:field-rebar-specification ,
        ppdoc:field-rebar-diameter ,
        ppdoc:field-length ,
        ppdoc:field-count ,
        ppdoc:field-unit-weight ,
        ppdoc:field-calculated-weight ;
    ppdoc:hasPart ppdoc:rebar-quantity-item-sample-001 ;
    ppdoc:isQuantityBasisFor ppdoc:rebar-detail-sample-001 .

ppdoc:concrete-quantity-sheet-sample
    a ppdoc:ConcreteQuantityCalculationSheet ;
