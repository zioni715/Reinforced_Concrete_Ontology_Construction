ppdoc:summary-rebar-work-sample
    a ppdoc:SummaryAmount ;
    rdfs:label "철근공사 집계금액"@ko ;
    ppdoc:hasAmount "120000000"^^xsd:decimal ;
    ppdoc:hasCurrency "KRW" ;
