#################################################################
# Actors
#################################################################

ppdoc:contractor-13
    a ppdoc:Contractor ;
    rdfs:label "시공사"@ko .

ppdoc:site-office-13
    a ppdoc:SiteOffice ;
    rdfs:label "현장"@ko .

ppdoc:supervision-head-office-13
    a ppdoc:SupervisionHeadOffice ;
    rdfs:label "감리본사"@ko .

ppdoc:head-office-13
    a ppdoc:HeadOffice ;
    rdfs:label "본사"@ko .

ppdoc:owner-13
    a ppdoc:Owner ;
    rdfs:label "발주처"@ko .

ppdoc:inspector-13
    a ppdoc:Inspector ;
    rdfs:label "기성검사자"@ko .

#################################################################
# Contractor progress payment package
#################################################################

ppdoc:progress-payment-package-13
    a ppdoc:ContractorProgressPaymentPackage ;
    rdfs:label "제13회 시공사 기성서류"@ko ;
    ppdoc:hasDocumentIdentifier "13" ;
    ppdoc:hasDocumentTitle "제13회 기성검사(정식, 개산급) 결과보고" ;
    ppdoc:hasSourceFileName "0 공문 - 제 13회 기성검사(정식, 개산급) 결과보고[화성동탄(2) A4-1BL].pdf" ;
    ppdoc:createdBy ppdoc:contractor-13 ;
    ppdoc:submittedBy ppdoc:contractor-13 ;
    ppdoc:submittedTo ppdoc:site-office-13 ;
    ppdoc:hasPart ppdoc:official-letter-13 ,
        ppdoc:attachment-bundle-13 .

ppdoc:official-letter-13
    a ppdoc:OfficialLetter ;
    rdfs:label "공문"@ko ;
    ppdoc:hasDocumentTitle "제13회 기성검사 결과보고 공문" ;
    ppdoc:isPartOf ppdoc:progress-payment-package-13 .

ppdoc:attachment-bundle-13
    a ppdoc:AttachmentBundle ;
    rdfs:label "첨부서류"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-package-13 ;
    ppdoc:attaches ppdoc:inspection-request-13 ,
        ppdoc:statement-document-13 ,
        ppdoc:material-ledger-13 ,
        ppdoc:inspection-photo-group-13 ;
    ppdoc:conditionallyIncludes ppdoc:advance-deduction-13 ,
        ppdoc:safety-cost-evidence-13 ,
        ppdoc:insurance-certificate-13 ,
        ppdoc:owner-requested-document-13 .

ppdoc:inspection-request-13
    a ppdoc:ProgressPaymentInspectionRequest ;
    rdfs:label "기성부분 검사원"@ko ;
    ppdoc:hasSourceFileName "1. 기성검사조서(cotis 생성문서).hwp" .

ppdoc:advance-deduction-13
    a ppdoc:AdvancePaymentDeductionStatement ;
    rdfs:label "선금공제 내역"@ko .

ppdoc:safety-cost-evidence-13
    a ppdoc:SafetyCostEvidenceDocument ;
    rdfs:label "안전관리비 사용내역 및 증빙"@ko .

ppdoc:insurance-certificate-13
    a ppdoc:InsurancePaymentCertificate ;
    rdfs:label "보험료 납입 증명서"@ko .

ppdoc:owner-requested-document-13
    a ppdoc:OwnerRequestedDocument ;
    rdfs:label "기타 발주처 요청 서류"@ko .

