@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#################################################################
# Actors
#################################################################

ppdoc:contractor-sample
    a ppdoc:Contractor ;
    rdfs:label "시공사"@ko .

ppdoc:site-office-sample
    a ppdoc:SiteOffice ;
    rdfs:label "현장"@ko .

ppdoc:supervision-head-office-sample
    a ppdoc:SupervisionHeadOffice ;
    rdfs:label "감리본사"@ko .

ppdoc:head-office-sample
    a ppdoc:HeadOffice ;
    rdfs:label "본사"@ko .

ppdoc:owner-sample
    a ppdoc:Owner ;
    rdfs:label "발주처"@ko .

ppdoc:inspector-sample
    a ppdoc:Inspector ;
    rdfs:label "기성검사자"@ko .

#################################################################
# Contractor progress payment package
#################################################################

ppdoc:progress-payment-package-sample
    a ppdoc:ContractorProgressPaymentPackage ;
    rdfs:label "시공사 기성서류"@ko ;
    ppdoc:hasDocumentIdentifier "validation-sample" ;
    ppdoc:hasDocumentTitle "기성검사 결과보고" ;
    ppdoc:hasSourceFileName "검증용 실제 사례 문서: 기성검사 결과보고 PDF" ;
    ppdoc:createdBy ppdoc:contractor-sample ;
    ppdoc:submittedBy ppdoc:contractor-sample ;
    ppdoc:submittedTo ppdoc:site-office-sample ;
    ppdoc:hasPart ppdoc:official-letter-sample ,
        ppdoc:attachment-bundle-sample .

ppdoc:official-letter-sample
    a ppdoc:OfficialLetter ;
    rdfs:label "공문"@ko ;
    ppdoc:hasDocumentTitle "기성검사 결과보고 공문" ;
    ppdoc:isPartOf ppdoc:progress-payment-package-sample .

ppdoc:attachment-bundle-sample
    a ppdoc:AttachmentBundle ;
    rdfs:label "첨부서류"@ko ;
    ppdoc:isPartOf ppdoc:progress-payment-package-sample ;
    ppdoc:attaches ppdoc:inspection-request-sample ,
        ppdoc:statement-document-sample ,
        ppdoc:material-ledger-sample ,
        ppdoc:inspection-photo-group-sample ;
    ppdoc:conditionallyIncludes ppdoc:advance-deduction-sample ,
        ppdoc:safety-cost-evidence-sample ,
        ppdoc:insurance-certificate-sample ,
        ppdoc:owner-requested-document-sample .

ppdoc:inspection-request-sample
    a ppdoc:ProgressPaymentInspectionRequest ;
    rdfs:label "기성부분 검사원"@ko ;
    ppdoc:hasSourceFileName "1. 기성검사조서(cotis 생성문서).hwp" .

ppdoc:advance-deduction-sample
    a ppdoc:AdvancePaymentDeductionStatement ;
    rdfs:label "선금공제 내역"@ko .

ppdoc:safety-cost-evidence-sample
    a ppdoc:SafetyCostEvidenceDocument ;
    rdfs:label "안전관리비 사용내역 및 증빙"@ko .

ppdoc:insurance-certificate-sample
    a ppdoc:InsurancePaymentCertificate ;
    rdfs:label "보험료 납입 증명서"@ko .

ppdoc:owner-requested-document-sample
    a ppdoc:OwnerRequestedDocument ;
    rdfs:label "기타 발주처 요청 서류"@ko .

#################################################################
# Statement document hierarchy
#################################################################

ppdoc:statement-document-sample
    a ppdoc:StatementDocument ;
    rdfs:label "내역서"@ko ;
    ppdoc:hasSourceFileName "3. 기성 세부내역.xlsx" ;
    ppdoc:hasPart ppdoc:claim-summary-sample ,
        ppdoc:progress-payment-statement-sample .

ppdoc:claim-summary-sample
    a ppdoc:ProgressPaymentClaimSummary ;
    rdfs:label "청구기성 요약"@ko ;
    ppdoc:hasAmount "350000000"^^xsd:decimal ;
    ppdoc:hasCurrency "KRW" .

ppdoc:progress-payment-statement-sample
    a ppdoc:ProgressPaymentStatement ;
    rdfs:label "공사기성부분 내역서"@ko ;
