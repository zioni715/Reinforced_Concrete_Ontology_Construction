#################################################################
# Review, inspection, approval flow
#################################################################

ppdoc:site-to-supervision-package-13
    a ppdoc:SiteToSupervisionSubmissionPackage ;
    rdfs:label "현장-감리본사 공문발송 문서군"@ko ;
    ppdoc:forwardedBy ppdoc:site-office-13 ;
    ppdoc:forwardedTo ppdoc:supervision-head-office-13 ;
    ppdoc:hasPart ppdoc:supervision-report-13 ,
        ppdoc:inspection-plan-13 ,
        ppdoc:inspection-request-13 .

ppdoc:supervision-report-13
    a ppdoc:SupervisionProgressPaymentReport ;
    rdfs:label "기성부분 감리조서"@ko ;
    ppdoc:reviewedBy ppdoc:supervision-head-office-13 .

ppdoc:inspection-plan-13
    a ppdoc:InspectionExecutionPlan ;
    rdfs:label "공사 기성검사 수행계획서"@ko ;
    ppdoc:hasPart ppdoc:detailed-execution-plan-13 ,
        ppdoc:prior-review-opinion-13 .

ppdoc:detailed-execution-plan-13
    a ppdoc:DetailedExecutionPlan ;
    rdfs:label "세부 수행계획서"@ko .

ppdoc:prior-review-opinion-13
    a ppdoc:PriorReviewOpinion ;
    rdfs:label "기성검사원에 대한 사전검토 의견서"@ko .

ppdoc:head-office-to-owner-package-13
    a ppdoc:HeadOfficeToOwnerSubmissionPackage ;
    rdfs:label "본사-발주처 공문발송 문서군"@ko ;
    ppdoc:forwardedBy ppdoc:head-office-13 ;
    ppdoc:submittedTo ppdoc:owner-13 ;
    ppdoc:hasPart ppdoc:inspector-appointment-notice-13 ;
    ppdoc:attaches ppdoc:site-to-supervision-package-13 .

ppdoc:inspector-appointment-notice-13
    a ppdoc:InspectorAppointmentNotice ;
    rdfs:label "검사자 임명 및 검사일자 통보"@ko .

ppdoc:progress-payment-inspection-13
    a ppdoc:ProgressPaymentInspection ;
    rdfs:label "제13회 기성검사"@ko ;
    ppdoc:inspectedBy ppdoc:inspector-13 ;
    ppdoc:hasPart ppdoc:document-inspection-13 ,
        ppdoc:site-inspection-13 ,
        ppdoc:inspection-photo-sheet-13 ;
    ppdoc:precedes ppdoc:inspection-result-report-13 .

ppdoc:document-inspection-13
    a ppdoc:DocumentInspection ;
    rdfs:label "서류검사"@ko .

ppdoc:site-inspection-13
    a ppdoc:SiteInspection ;
    rdfs:label "현장검사"@ko .

ppdoc:inspection-photo-sheet-13
    a ppdoc:PhotoSheet ;
    rdfs:label "검사사진 대지"@ko ;
    ppdoc:isPhotoEvidenceFor ppdoc:progress-payment-inspection-13 .

ppdoc:inspection-result-report-13
    a ppdoc:InspectionResultReportPackage ;
    rdfs:label "기성검사 결과 보고"@ko ;
    ppdoc:submittedTo ppdoc:owner-13 ;
    ppdoc:hasPart ppdoc:inspection-record-13 ,
        ppdoc:review-opinion-13 ,
        ppdoc:attendance-confirmation-13 ,
        ppdoc:result-photo-attachment-13 ;
    ppdoc:precedes ppdoc:owner-approval-13 .

ppdoc:inspection-record-13
    a ppdoc:ProgressPaymentInspectionRecord ;
    rdfs:label "제13회 기성검사 조서"@ko ;
    ppdoc:hasSourceFileName "1. 제 13회 기성검사조서(정식, 개산급).PDF" .

ppdoc:review-opinion-13
    a ppdoc:ProgressPaymentReviewOpinion ;
    rdfs:label "기성검토의견서"@ko .

ppdoc:attendance-confirmation-13
    a ppdoc:ConstructionManagerAttendanceConfirmation ;
    rdfs:label "공사관리관 입회확인서"@ko .

ppdoc:result-photo-attachment-13
    a ppdoc:PhotoSheet ;
    rdfs:label "사진첨부"@ko .

ppdoc:owner-approval-13
    a ppdoc:OwnerApproval ;
    rdfs:label "발주처 승인"@ko ;
    ppdoc:approvedBy ppdoc:owner-13 ;
    ppdoc:precedes ppdoc:bound-statement-submission-13 .

ppdoc:bound-statement-submission-13
    a ppdoc:BoundStatementSubmission ;
    rdfs:label "기성서류 내역서 제본 제출"@ko .
